# Google Maps (optional — if unset, Leaflet + Carto/MapTiler is used)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Google sign-in: the consent screen title/logo comes from Google Cloud → APIs & Services → OAuth consent screen (set App name / branding to Maimo Map). Supabase only brokers the redirect.

# MapTiler (optional — improves raster tiles when not using Google)
NEXT_PUBLIC_MAPTILER_API_KEY=
NEXT_PUBLIC_MAPTILER_MAP_ID=basic-v2

# Supabase (optional — if unset, map uses local spots only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
#
# Google account chooser may show “continue to *.supabase.co” — that is the OAuth redirect host.
# To use your brand domain: enable Supabase Custom domain (paid, e.g. api.maimo.net) or vanity subdomain
# (e.g. YOUR_PROJECT.supabase.co), then set NEXT_PUBLIC_SUPABASE_URL to that HTTPS URL, add the matching
# /auth/v1/callback in the Google Cloud OAuth client, and sync Supabase Auth redirect URLs.
# https://supabase.com/docs/guides/platform/custom-domains

# Optional: canonical public site URL (https://your-domain.com) for magic-link redirects.
# If unset, the app uses the current browser origin (correct for local dev and most deployments).
NEXT_PUBLIC_SITE_URL=

# Optional: single exact redirect URL for email OTP / magic links (must match Supabase “Redirect URLs”).
# Use when NEXT_PUBLIC_SITE_URL / origin mismatch causes “redirect URL not allowed” on send code.
NEXT_PUBLIC_SUPABASE_EMAIL_REDIRECT_TO=

# Capacitor APK/AAB only: set true to force native OAuth redirect `maimomap://auth/callback`
# (normally auto-detected via Capacitor.isNativePlatform()).
NEXT_PUBLIC_CAPACITOR_OAUTH_NATIVE=

#
# Supabase → Authentication → URL configuration — add:
#   maimomap://auth/callback
#   https://london-budget-map.vercel.app/auth/callback
#   https://london-budget-map.vercel.app
# Email templates: copy from supabase/email_templates/magic_link_supabase_dashboard.html (8-digit copy).

# Moderation (static export cannot ship Next /api routes — use Supabase Edge Functions + this base URL)
# Example: https://YOUR_PROJECT_REF.supabase.co/functions/v1
# Deploy: supabase functions deploy approve-submission reject-submission moderation-me
# Set the same MODERATOR_EMAILS secret on each function in the Supabase dashboard.
NEXT_PUBLIC_MODERATION_API_BASE_URL=

# Edge Function secrets (set in Supabase → Edge Functions → Secrets, not in Next):
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, MODERATOR_EMAILS (comma-separated, same as below)

# Server-only (never expose to the browser). Optional for local scripts or a separate Node API.
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated moderator sign-in emails (must match Edge Function secret MODERATOR_EMAILS).
MODERATOR_EMAILS=
# Optional: future cron / server job auth.
MODERATION_CRON_SECRET=
