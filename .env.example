# Google Maps (optional — if unset, Leaflet + Carto/MapTiler is used)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# MapTiler (optional — improves raster tiles when not using Google)
NEXT_PUBLIC_MAPTILER_API_KEY=
NEXT_PUBLIC_MAPTILER_MAP_ID=basic-v2

# Supabase (optional — if unset, map uses local spots only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: canonical public site URL (https://your-domain.com) for magic-link redirects.
# If unset, the app uses the current browser origin (correct for local dev and most deployments).
NEXT_PUBLIC_SITE_URL=

# Moderation (server only — never expose service role to the browser)
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated sign-in emails allowed to call /api/moderation/* (approve, reject, evaluate-expired).
MODERATOR_EMAILS=
# Optional: POST /api/moderation/evaluate-expired with Authorization: Bearer <this> (e.g. cron) without a user session.
MODERATION_CRON_SECRET=
